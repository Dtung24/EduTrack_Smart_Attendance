@startuml
left to right direction
skinparam packageStyle rectangle

actor Student
actor Lecturer
actor Admin
actor AI_System

rectangle "EduTrack FSM System" {

  usecase "RFID Check-in" as UC1
  usecase "RFID Check-out" as UC2
  usecase "Anti-Passback Validation" as UC3
  usecase "Sync Time via NTP" as UC4
  usecase "Store Attendance Log" as UC5
  usecase "View Attendance Dashboard" as UC6
  usecase "Generate Attendance Report" as UC7
  usecase "Analyze Abnormal Behavior" as UC8
  usecase "Send Fraud Warning" as UC9
  usecase "Manage Students" as UC10
  usecase "Manage RFID Cards" as UC11
}

Student --> UC1
Student --> UC2

Lecturer --> UC6
Lecturer --> UC7

Admin --> UC10
Admin --> UC11

UC1 --> UC3 : <<include>>
UC2 --> UC3 : <<include>>

UC1 --> UC5 : <<include>>
UC2 --> UC5 : <<include>>

UC5 --> UC8 : <<include>>

AI_System --> UC8
AI_System --> UC9

UC4 --> UC5

@enduml